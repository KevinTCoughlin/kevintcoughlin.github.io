{
  "name": "kevintcoughlin.github.io",
  "version": "1.0.0",
  "description": "My personal website",
  "scripts": {
    "start": "http-server -o",
    "stage": "bash scripts/stage-site.sh _site",
    "preview": "bun run stage && http-server _site -o -p 8080",
    "preview:docker": "docker compose up --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "validate": "bun run lint && bun run format"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KevinTCoughlin/kevintcoughlin.github.io.git"
  },
  "author": "Kevin Coughlin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KevinTCoughlin/kevintcoughlin.github.io/issues"
  },
  "homepage": "https://kevintcoughlin.com",
  "devDependencies": {
    "@html-eslint/eslint-plugin": "^0.62.0",
    "@html-eslint/parser": "^0.62.0",
    "eslint": "^10.5.0",
    "http-server": "^14.1.1",
    "prettier": "^3.8.4"
  },
  "packageManager": "bun@1.3.14"
}
